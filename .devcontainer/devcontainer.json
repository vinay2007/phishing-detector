{
    "name": "AI-Sentinel Pro Engine",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/node-js:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "AI Sentinel API",
            "onAutoForward": "openBrowser"
        }
    },
    "postCreateCommand": "pip install -r requirements.txt && playwright install --with-deps chromium",
    "remoteUser": "vscode"
}
